# Copy this file to .env and set your own values
PORT=3000
NODE_ENV=development
PAYMENT_MODE=mock
PAYMENT_CURRENCY=EUR
# Optional: Google Sheets CSV or normal sheet URL for automatic menu sync
# Example CSV URL:
# GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/PASTE_SHEET_ID/export?format=csv&gid=0
# Example normal sheet URL:
# GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/PASTE_SHEET_ID/edit#gid=0
GOOGLE_SHEETS_CSV_URL=
GOOGLE_SHEETS_SIZES_URL=
GOOGLE_SHEETS_EXTRAS_URL=
GOOGLE_SHEETS_REFRESH_MS=300000
OPENAI_API_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
